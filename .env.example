# Copy this file to .env for local development.
# Keep real credentials and machine-specific paths out of version control.

# Launcher runtime label. Reserved for environment-specific behavior.
JIFERCRAFT_ENV=development

# Required only when Microsoft premium sign-in is enabled in the UI.
# Create a public/native Microsoft Entra app and enable device code authentication.
MICROSOFT_CLIENT_ID=

# Optional on Windows. If the launcher setting "Java path" is empty,
# the main process checks JAVA_HOME/bin/javaw.exe before falling back to javaw.
JAVA_HOME=

# Managed by electron-vite during development. Leave empty in normal .env files.
ELECTRON_RENDERER_URL=
